CC     = gcc
CFLAGS = -Wall -Wextra -Iinclude

SRC = main.c \
      src/room.c \
      src/customer.c \
      src/booking.c \
      src/service.c \
      src/bill.c \
      src/auth.c \
      src/report.c \
      src/file.c \
      src/menu.c \
      src/utils.c

# Chi build cac file da ton tai (dung cho tung ngay)
SRC_DAY1 = main.c \
            src/room.c \
            src/menu.c \
            src/utils.c

TARGET = hotel

# Build day du (sau ngay 6)
all:
	$(CC) $(SRC) -o $(TARGET) $(CFLAGS)

# Build ngay 1 (chi co room module)
day1:
	$(CC) $(SRC_DAY1) -o $(TARGET) $(CFLAGS)

run:
	./$(TARGET)

clean:
	rm -f $(TARGET)

.PHONY: all day1 run clean